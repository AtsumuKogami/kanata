<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Kanata.Hub.App"
             RequestedThemeVariant="Dark">
  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://Kanata.Hub/Theme/Palette.axaml" />
    <StyleInclude Source="avares://Kanata.Hub/Theme/Components.axaml" />
  </Application.Styles>
</Application>

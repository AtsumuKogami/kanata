<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource Kanata.Brush.Text}" />
    <Setter Property="FontFamily" Value="Segoe UI, Inter, Arial" />
  </Style>

  <Style Selector="TextBlock.page-title">
    <Setter Property="FontSize" Value="30" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.page-subtitle">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Foreground" Value="{DynamicResource Kanata.Brush.TextMuted}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style Selector="TextBlock.muted">
    <Setter Property="Foreground" Value="{DynamicResource Kanata.Brush.TextMuted}" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <Style Selector="TextBlock.sidebar-kicker">
    <Setter Property="Foreground" Value="{DynamicResource Kanata.Brush.Accent}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.sidebar-title">
    <Setter Property="FontSize" Value="32" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.navigation-title">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.navigation-description">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Foreground" Value="{DynamicResource Kanata.Brush.TextMuted}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style Selector="TextBlock.section-title">
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.hint-title">
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource Kanata.Brush.Accent}" />
  </Style>

  <Style Selector="TextBlock.footer-note">
    <Setter Property="Foreground" Value="{DynamicResource Kanata.Brush.TextSubtle}" />
    <Setter Property="FontSize" Value="11" />
  </Style>

  <Style Selector="Border.hub-surface">
    <Setter Property="Background" Value="{DynamicResource Kanata.Brush.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Kanata.Brush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="18" />
  </Style>

  <Style Selector="Border.main-content">
    <Setter Property="Padding" Value="28" />
  </Style>

  <Style Selector="Border.sidebar">
    <Setter Property="Padding" Value="18" />
    <Setter Property="Background" Value="{DynamicResource Kanata.Brush.SurfaceRaised}" />
  </Style>

  <Style Selector="Border.section-card">
    <Setter Property="Background" Value="{DynamicResource Kanata.Brush.SurfaceRaised}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Kanata.Brush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="Padding" Value="18" />
  </Style>

  <Style Selector="Border.hint-card">
    <Setter Property="Background" Value="{DynamicResource Kanata.Brush.AccentSoft}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Kanata.Brush.AccentBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Padding" Value="12" />
  </Style>

  <Style Selector="Button">
    <Setter Property="Padding" Value="14,8" />
    <Setter Property="Background" Value="{DynamicResource Kanata.Brush.SurfaceRaised}" />
    <Setter Property="Foreground" Value="{DynamicResource Kanata.Brush.Text}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Kanata.Brush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
  </Style>

  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{DynamicResource Kanata.Brush.Accent}" />
    <Setter Property="Foreground" Value="#151515" />
    <Setter Property="BorderBrush" Value="{DynamicResource Kanata.Brush.Accent}" />
  </Style>

  <Style Selector="Button.secondary">
    <Setter Property="Background" Value="{DynamicResource Kanata.Brush.AccentSoft}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Kanata.Brush.AccentBorder}" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="Background" Value="{DynamicResource Kanata.Brush.WindowBackground}" />
    <Setter Property="Foreground" Value="{DynamicResource Kanata.Brush.Text}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Kanata.Brush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="12,9" />
  </Style>

  <Style Selector="ListBox.navigation-list">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="ListBox.navigation-list ListBoxItem">
    <Setter Property="Padding" Value="12,10" />
    <Setter Property="Margin" Value="0,0,0,8" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="ListBox.navigation-list ListBoxItem:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Kanata.Brush.SurfaceHover}" />
  </Style>

  <Style Selector="ListBox.navigation-list ListBoxItem:selected /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource Kanata.Brush.AccentSoft}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Kanata.Brush.AccentBorder}" />
  </Style>

</Styles>

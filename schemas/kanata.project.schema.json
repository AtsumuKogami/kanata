{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.kanata.dev/project/v1/kanata.project.schema.json",
  "title": "Kanata Project",
  "description": "Kanata project file schema.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "schemaVersion",
    "id",
    "name",
    "kanataVersion",
    "paths",
    "source",
    "features",
    "targets",
    "start"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "format": {
      "const": "kanata.project"
    },
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "projectVersion": {
      "type": "string"
    },
    "kanataVersion": {
      "type": "string",
      "minLength": 1
    },
    "paths": {
      "$ref": "#/$defs/paths"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "targets": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/target"
      }
    },
    "start": {
      "$ref": "#/$defs/start"
    }
  },
  "$defs": {
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content", "source", "generated", "settings"],
      "properties": {
        "content": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "generated": {
          "type": "string",
          "minLength": 1
        },
        "settings": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shared", "logic", "view"],
      "properties": {
        "shared": {
          "type": "string",
          "minLength": 1
        },
        "logic": {
          "type": "string",
          "minLength": 1
        },
        "view": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform", "backend", "hostProject", "session"],
      "properties": {
        "platform": {
          "type": "string",
          "minLength": 1
        },
        "backend": {
          "type": "string",
          "minLength": 1
        },
        "hostProject": {
          "type": "string",
          "minLength": 1
        },
        "session": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "start": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scene"],
      "properties": {
        "scene": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.kanata.dev/project/v1/kanata.project.schema.json",
  "title": "Kanata Project",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "schemaVersion",
    "id",
    "name",
    "kanataVersion",
    "paths",
    "source",
    "features",
    "targets",
    "start"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "format": {
      "const": "kanata.project"
    },
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]*[a-z0-9]$|^[a-z0-9]$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "projectVersion": {
      "type": "string"
    },
    "kanataVersion": {
      "type": "string",
      "minLength": 1
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content", "source", "generated", "settings"],
      "properties": {
        "content": { "type": "string" },
        "source": { "type": "string" },
        "generated": { "type": "string" },
        "settings": { "type": "string" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shared", "logic", "view"],
      "properties": {
        "shared": { "type": "string" },
        "logic": { "type": "string" },
        "view": { "type": "string" }
      }
    },
    "features": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "targets": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["platform", "backend", "hostProject", "session"],
        "properties": {
          "platform": { "type": "string" },
          "backend": { "type": "string" },
          "hostProject": { "type": "string" },
          "session": { "type": "string" }
        }
      }
    },
    "start": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scene"],
      "properties": {
        "scene": { "type": "string" }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.kanata.dev/lock/v1/kanata.lock.schema.json",
  "title": "Kanata Lock File",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "schemaVersion",
    "projectId",
    "kanataVersion",
    "target",
    "configuration",
    "generatedAtUtc",
    "components"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "format": {
      "const": "kanata.lock"
    },
    "schemaVersion": {
      "const": 1
    },
    "projectId": {
      "type": "string",
      "minLength": 1
    },
    "kanataVersion": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "string",
      "minLength": 1
    },
    "configuration": {
      "type": "string",
      "minLength": 1
    },
    "generatedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "components": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/component"
      }
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "kind",
        "source",
        "targetFramework",
        "assemblyName",
        "assemblyPath",
        "dependencies"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "targetFramework": {
          "type": "string",
          "minLength": 1
        },
        "assemblyName": {
          "type": "string",
          "minLength": 1
        },
        "assemblyPath": {
          "type": "string",
          "minLength": 1
        },
        "manifestPath": {
          "type": ["string", "null"]
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
